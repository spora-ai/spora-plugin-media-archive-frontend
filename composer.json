{
    "name": "spora-ai/spora-plugin-media-archive-frontend",
    "description": "Pre-built Vue SPA for browsing, filtering, and downloading Spora media-archive rows. Delivered as type `spora-plugin-frontend`; the host SPA lazy-loads it via /plugins/spora-plugin-media-archive-frontend/main.js.",
    "type": "spora-plugin-frontend",
    "license": "MIT",
    "require": {
        "php": "^8.4.1"
    },
    "dist": {
        "url": "https://github.com/spora-ai/spora-plugin-media-archive-frontend/releases/download/v0.1.4/spora-plugin-media-archive-frontend-v0.1.4.tar.gz",
        "type": "tar"
    },
    "extra": {
        "_comment": "Must equal plugin.json#slug in spora-plugin-media-archive; SporaPluginFrontendInstaller refuses to install when missing.",
        "spora-plugin-slug": "media-archive"
    },
    "archive": {
        "exclude": [
            "/.github",
            "/node_modules",
            "/src",
            "/tests",
            "/coverage",
            "/scripts",
            "/.git",
            "/.gitkeep",
            "/.gitignore",
            "/.DS_Store",
            "/package-lock.json",
            "/package.json",
            "/eslint.config.js",
            "/postcss.config.js",
            "/tailwind.config.ts",
            "/tsconfig.json",
            "/vite.config.ts",
            "/index.html",
            "/sonar-project.properties",
            "/README.md",
            "/RELEASING.md"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "spora-ai/installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}